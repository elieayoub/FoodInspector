@model FoodInspector.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card shadow border-0">
            <div class="card-body text-center">
                <div class="mb-3" style="font-size: 4rem;">🥦</div>
                <h2 class="card-title fw-bold text-success">Food Inspector</h2>
                <p class="text-muted">
                    Create your account to scan food ingredients and track your daily health.
                </p>
                <hr />

                <form asp-action="Register" method="post">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-person"></i> Your Name
                        </label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g. Sarah" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-envelope"></i> Email
                        </label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="you@example.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-lock"></i> Password
                        </label>
                        <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="At least 6 characters" required />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-lock-fill"></i> Confirm Password
                        </label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" placeholder="Re-enter password" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-heart"></i> Your Age
                        </label>
                        <input asp-for="Age" type="number" min="1" max="120"
                               class="form-control form-control-lg" placeholder="e.g. 30" required />
                        <span asp-validation-for="Age" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 mt-2">
                        <i class="bi bi-check-circle"></i> Create Account
                    </button>
                </form>

                <hr />
                <p class="mb-0">
                    Already have an account?
                    <a asp-action="Login" class="fw-semibold text-success">Sign in</a>
                </p>
            </div>
        </div>

        <p class="text-center text-muted small mt-3">
            Your age helps us give you tailored health advice. <br />
            We never share your data.
        </p>
    </div>
</div>
