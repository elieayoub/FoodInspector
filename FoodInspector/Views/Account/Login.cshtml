@model FoodInspector.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card shadow border-0">
            <div class="card-body text-center">
                <div class="mb-3" style="font-size: 4rem;">🥦</div>
                <h2 class="card-title fw-bold text-success">Food Inspector</h2>
                <p class="text-muted">Sign in to track what you eat and monitor your health.</p>
                <hr />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger small"></div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-envelope"></i> Email
                        </label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="you@example.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-lock"></i> Password
                        </label>
                        <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="••••••" required />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 mt-2">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </button>
                </form>

                <hr />
                <p class="mb-0">
                    Don't have an account?
                    <a asp-action="Register" class="fw-semibold text-success">Register here</a>
                </p>
            </div>
        </div>
    </div>
</div>
