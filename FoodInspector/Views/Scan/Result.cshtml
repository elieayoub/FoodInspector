@model FoodInspector.Models.ScanViewModel
@{
    ViewData["Title"] = "Analysis Result";

    string verdictColor = Model.Analysis?.OverallVerdict switch
    {
        "Buy" => "success",
        "Caution" => "warning",
        "Avoid" => "danger",
        _ => "secondary"
    };

    string verdictIcon = Model.Analysis?.OverallVerdict switch
    {
        "Buy" => "bi-hand-thumbs-up-fill",
        "Caution" => "bi-exclamation-triangle-fill",
        "Avoid" => "bi-x-octagon-fill",
        _ => "bi-question-circle"
    };

    string verdictEmoji = Model.Analysis?.OverallVerdict switch
    {
        "Buy" => "✅",
        "Caution" => "⚠️",
        "Avoid" => "🚫",
        _ => "❓"
    };
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Overall Verdict Card -->
        <div class="card border-@verdictColor shadow mb-3">
            <div class="card-body text-center">
                <div style="font-size:3rem;">@verdictEmoji</div>
                <h2 class="fw-bold text-@verdictColor">
                    <i class="bi @verdictIcon"></i> @Model.Analysis?.OverallVerdict
                </h2>
                <p class="lead mb-0">@Model.Analysis?.Summary</p>
            </div>
        </div>

        <!-- Captured Image Thumbnail -->
        @if (!string.IsNullOrWhiteSpace(Model.ImageBase64))
        {
            <div class="text-center mb-3">
                <img src="@Model.ImageBase64" class="img-fluid rounded shadow-sm" style="max-height:200px;" alt="Scanned label" />
            </div>
        }

        <!-- Extracted Text (editable) -->
        @if (!string.IsNullOrWhiteSpace(Model.ExtractedText))
        {
            <div class="card mb-3">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-card-text"></i> Extracted Text (OCR)</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="editTextBtn" onclick="toggleEdit()">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                </div>
                <div class="card-body">
                    <!-- Read-only view -->
                    <pre id="textReadonly" class="mb-0" style="white-space:pre-wrap; font-size:0.85rem;">@Model.ExtractedText</pre>

                    <!-- Editable form (hidden by default) -->
                    <form id="reanalyzeForm" asp-controller="Scan" asp-action="Reanalyze" method="post" style="display:none;">
                        <textarea name="extractedText" id="editableText" class="form-control mb-2" rows="6" style="font-size:0.85rem;">@Model.ExtractedText</textarea>
                        <input type="hidden" name="imageData" value="@Model.ImageBase64" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-arrow-clockwise"></i> Re-analyze
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="cancelEdit()">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }

        <!-- Ingredient Details -->
        @if (Model.Analysis?.Ingredients?.Any() == true)
        {
            <h5 class="fw-bold mt-3"><i class="bi bi-list-check"></i> Ingredient Breakdown</h5>
            <div class="list-group mb-3">
                @foreach (var ing in Model.Analysis.Ingredients)
                {
                    var badgeClass = ing.Status switch
                    {
                        "Good" => "bg-success",
                        "Neutral" => "bg-secondary",
                        "Bad" => "bg-danger",
                        _ => "bg-secondary"
                    };

                    var icon = ing.Status switch
                    {
                        "Good" => "bi-check-circle-fill text-success",
                        "Neutral" => "bi-dash-circle text-secondary",
                        "Bad" => "bi-x-circle-fill text-danger",
                        _ => "bi-question-circle"
                    };

                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <i class="bi @icon"></i>
                                <strong>@ing.Name</strong>
                            </div>
                            <span class="badge @badgeClass rounded-pill">@ing.Status</span>
                        </div>
                        <small class="text-muted">@ing.Reason</small>
                    </div>
                }
            </div>
        }

        <!-- Add Missing Ingredient -->
        @if (Model.ScanResultId.HasValue)
        {
            <div class="card border-info mb-3">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-plus-circle"></i> Missing an ingredient?</span>
                    <button type="button" class="btn btn-sm btn-outline-light" id="addIngBtn" onclick="toggleAddIngredient()">
                        <i class="bi bi-plus"></i> Add
                    </button>
                </div>
                <div id="addIngredientForm" class="card-body" style="display:none;">
                    <form asp-controller="Scan" asp-action="AddIngredient" method="post">
                        <input type="hidden" name="scanResultId" value="@Model.ScanResultId" />
                        <input type="hidden" name="imageData" value="@Model.ImageBase64" />
                        <div class="mb-2">
                            <label class="form-label fw-bold">Ingredient Name</label>
                            <input type="text" name="ingredientName" class="form-control" placeholder="e.g. Turmeric" required />
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-bold">Classification</label>
                            <select name="ingredientStatus" class="form-select">
                                <option value="Good">✅ Good</option>
                                <option value="Neutral" selected>⚪ Neutral</option>
                                <option value="Bad">🚫 Bad</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-bold">Reason <small class="text-muted">(optional)</small></label>
                            <input type="text" name="ingredientReason" class="form-control" placeholder="e.g. Anti-inflammatory spice" />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-info btn-sm text-white">
                                <i class="bi bi-plus-circle"></i> Add &amp; Re-analyze
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAddIngredient()">
                                Cancel
                            </button>
                        </div>
                        <small class="text-muted mt-2 d-block">
                            <i class="bi bi-info-circle"></i> This ingredient will be saved and automatically recognized in future scans.
                        </small>
                    </form>
                </div>
            </div>
        }

        <!-- Actions -->
        <div class="d-flex gap-2 justify-content-center mb-4">
            @if (Model.ScanResultId.HasValue)
            {
                var iAteColor = Model.Analysis?.OverallVerdict == "Buy" ? "success" : "danger";
                <form asp-controller="Scan" asp-action="IAteThat" method="post" class="d-inline">
                    <input type="hidden" name="scanResultId" value="@Model.ScanResultId" />
                    <button type="submit" class="btn btn-@iAteColor btn-lg">
                        <i class="bi bi-egg-fried"></i> I Ate This
                    </button>
                </form>
            }
            <a asp-controller="Scan" asp-action="Index" class="btn btn-success btn-lg">
                <i class="bi bi-camera"></i> Scan Another
            </a>
            <a asp-controller="Dashboard" asp-action="Today" class="btn btn-outline-info btn-lg">
                <i class="bi bi-heart-pulse"></i> My Health
            </a>
            <a asp-controller="Scan" asp-action="History" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-clock-history"></i> History
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function toggleEdit() {
            document.getElementById('textReadonly').style.display = 'none';
            document.getElementById('editTextBtn').style.display = 'none';
            document.getElementById('reanalyzeForm').style.display = 'block';
            document.getElementById('editableText').focus();
        }

        function cancelEdit() {
            document.getElementById('textReadonly').style.display = 'block';
            document.getElementById('editTextBtn').style.display = 'inline-block';
            document.getElementById('reanalyzeForm').style.display = 'none';
            document.getElementById('editableText').value = document.getElementById('textReadonly').textContent;
        }

        function toggleAddIngredient() {
            var form = document.getElementById('addIngredientForm');
            var btn = document.getElementById('addIngBtn');
            if (form.style.display === 'none') {
                form.style.display = 'block';
                btn.style.display = 'none';
            } else {
                form.style.display = 'none';
                btn.style.display = 'inline-block';
            }
        }
    </script>
}
