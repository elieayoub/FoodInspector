@model List<FoodInspector.Models.ScanViewModel>
@{
    ViewData["Title"] = "Scan History";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

        <h4 class="fw-bold text-success mb-3">
            <i class="bi bi-clock-history"></i> Your Scan History
        </h4>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox" style="font-size:3rem;"></i>
                <p>No scans yet. Go scan your first product!</p>
                <a asp-controller="Scan" asp-action="Index" class="btn btn-success">
                    <i class="bi bi-camera"></i> Start Scanning
                </a>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                var verdictColor = item.Analysis?.OverallVerdict switch
                {
                    "Buy" => "success",
                    "Caution" => "warning",
                    "Avoid" => "danger",
                    _ => "secondary"
                };

                <div class="card mb-3 border-start border-4 border-@verdictColor">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-@verdictColor fs-6">@item.Analysis?.OverallVerdict</span>
                        </div>
                        <p class="small mb-1">@item.Analysis?.Summary</p>
                        @if (item.Analysis?.Ingredients != null)
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var ing in item.Analysis.Ingredients.Take(8))
                                {
                                    var bc = ing.Status == "Bad" ? "bg-danger" : ing.Status == "Good" ? "bg-success" : "bg-secondary";
                                    <span class="badge @bc">@ing.Name</span>
                                }
                                @if (item.Analysis.Ingredients.Count > 8)
                                {
                                    <span class="badge bg-light text-dark">+@(item.Analysis.Ingredients.Count - 8) more</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
