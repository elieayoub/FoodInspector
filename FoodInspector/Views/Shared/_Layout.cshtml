<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Food Inspector 🔍</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-success shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Scan" asp-action="Index">
                    🔍 Food Inspector
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Scan" asp-action="Index">
                                <i class="bi bi-camera"></i> Scan
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Today">
                                <i class="bi bi-heart-pulse"></i> My Health
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="HealthHistory">
                                <i class="bi bi-calendar-check"></i> History
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Scan" asp-action="History">
                                <i class="bi bi-clock-history"></i> Scans
                            </a>
                        </li>
                    </ul>
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <span class="navbar-text text-white me-2">
                            <i class="bi bi-person-circle"></i>
                            @Context.Session.GetString("UserName") (age @Context.Session.GetInt32("UserAge"))
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button class="btn btn-outline-light btn-sm">Logout</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3 mt-4">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - Food Inspector 🔍 — Eat smart, live healthy!
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
